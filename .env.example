# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# URL of your self-hosted Actual Budget server (e.g. http://actual:5006)
ACTUAL_SERVER_URL=http://actual:5006

# Actual Budget web password
ACTUAL_SERVER_PASSWORD=your_actual_password

# Budget file Sync ID (found in Settings → Show advanced settings → Sync ID)
ACTUAL_BUDGET_ID=your-budget-sync-id

# Secret API key for actual-http-api — generate any random string, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
ACTUAL_API_KEY=generate_a_random_secret_key

# Optional: comma-separated Telegram chat IDs allowed to use the bot
# Leave empty to allow anyone (not recommended for public bots)
ALLOWED_CHAT_IDS=
